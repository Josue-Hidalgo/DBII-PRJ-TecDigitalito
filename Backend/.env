PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:mongo_pw@localhost:27017/tecdigitalito_mongo_db?authSource=admin

# Redis
REDIS_URI=redis://localhost:6379

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j-pw

# Cassandra
CASSANDRA_HOST=localhost
CASSANDRA_DC=datacenter1

# Sesiones
SESSION_TTL_SECONDS=7200          # 2 horas (sliding window)

# Remember Me
REMEMBER_ME_TTL_SECONDS=2592000   # 30 días

# Intentos de login
LOGIN_ATTEMPTS_TTL_SECONDS=900    # 15 minutos
MAX_LOGIN_ATTEMPTS=5
SUSPICIOUS_THRESHOLD=3

# Bloqueo
BLOCK_TTL_SECONDS=1800            # 30 minutos

# Reset de contraseña
RESET_TOKEN_TTL_SECONDS=1200      # 20 minutos

# Notificaciones
NOTIFICATION_TTL_SECONDS=3600     # 1 hora
NOTIFICATION_MAX_RETRIES=3

# Historial de contraseñas
PASSWORD_HISTORY_LIMIT=5